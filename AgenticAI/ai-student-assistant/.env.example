# ─────────────────────────────────────────────
#  Copy this file to `.env` and fill in values
#  Never commit .env to version control!
# ─────────────────────────────────────────────

# ── LLM ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Which Claude model to use
# Supervisor / Answer Agent (smart, slower)
CLAUDE_SMART_MODEL=claude-sonnet-4-6
# Routing / quick decisions (fast, cheap)
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ── Embeddings ────────────────────────────────
# Local model – no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=student_docs

# ── RAG ──────────────────────────────────────
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4               # how many chunks to retrieve

# ── LangGraph ────────────────────────────────
MAX_ITERATIONS=10          # safety limit to prevent infinite loops
DEBUG_MODE=true            # print agent state at each step

# ── Paths ────────────────────────────────────
PDF_UPLOAD_DIR=./data/pdfs
